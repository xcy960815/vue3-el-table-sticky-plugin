{
  "compilerOptions": {
    "isolatedModules": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "removeComments": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "noLib": false,
    "target": "ES2015",
    "lib": ["ESNext", "DOM"],
    "paths": {
      "@/*": ["./src/*"],
      "@plugin/*": ["./plugin/*"]
    },
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationDir": "./temp",
    "noEmit": true
  },
  "exclude": [],
  "include": ["src/**/*.vue"],
  "files": [
    "plugin/index.ts",
    "plugin/table-sticky.ts",
    "plugin/type.ts",
    "plugin/utils.ts",
    "src/main.ts",
    "src/shims-vue.d.ts"
  ]
}
